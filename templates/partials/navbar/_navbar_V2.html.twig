{# templates/partials/navbar/_navbar_V2.html.twig #}

<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
  <div class="container">
    <a class="navbar-brand fw-bold" href="{{ path('app_home') }}">Teens-GRR</a>

    <button class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navMain">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navMain">
      <ul class="navbar-nav me-auto">
        <li class="nav-item mx-3">
          <a class="nav-link" href="{{ path('post_recent') }}">Flux</a>
        </li>
        {# barre verticale A REVOIR avec CSS #}
        {# <li class="nav-item border-start mx-3"></li> #}
        <li class="nav-item mx-3">
          <a class="nav-link" href="{{ path('post_trending') }}">
            <i class="bi bi-trophy"></i>
            Top
          </a>
        </li>
        <li class="nav-item mx-3">
          <a class="nav-link" href="{{ path('post_legend') }}">
            <i class="bi bi-bank me-1"></i>
            Légendes
          </a>
        </li>
        {# <li class="nav-item border-start mx-3"></li> #}
        <li class="nav-item d-flex align-items-center mx-2"></li>
        {% if is_granted('ROLE_MODERATOR') %}
          <li class="nav-item">
            <a class="nav-link text-warning"
              href="{{ path('moderation_dashboard') }}">
              🛡 Modération
            </a>
          </li>
        {% endif %}
      </ul>

      <ul class="navbar-nav">
        {% if app.user %}
          <li class="nav-item">
            <span class="nav-link text-light">
              👤
              {{ app.user.username }}
            </span>
          </li>
          {% if is_granted('ROLE_USER') %}
            <li class="nav-item">
              <a class="nav-link" href="{{ path('post_create') }}">
                + Nouveau post
              </a>
            </li>
          {% endif %}
          <li class="nav-item">
            <a class="nav-link" href="{{ path('app_logout') }}">Déconnexion</a>
          </li>
        {% else %}
          <li class="nav-item">
            <a class="nav-link" href="{{ path('app_login') }}">Connexion</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="{{ path('app_register') }}">
              Inscription
            </a>
          </li>
        {% endif %}
      </ul>
    </div>
  </div>
</nav>
