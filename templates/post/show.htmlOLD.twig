{# templates/post/show.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}{{ post.title }} — Teens-GRR{% endblock %}

{% block body %}

<div class="row justify-content-center">
    <div class="col-lg-10 col-xl-9">

        <article class="post-detail">

            {# Statut du post (si masqué ou supprimé) #}
            {% if not post.isVisible() %}
                <div class="alert alert-{{ post.isAutoModerated() ? 'warning' : 'danger' }} d-flex align-items-center gap-2 mb-4">
                    <i class="bi {% if post.isAutoModerated() %}bi-exclamation-triangle{% else %}bi-x-circle{% endif %} fs-4"></i>
                    <div>
                        {% if post.isAutoModerated() %}
                            Ce post a été <strong>masqué automatiquement</strong> suite à plusieurs signalements.<br>
                            Un modérateur l’examine actuellement.
                        {% elseif post.isManuallyModerated() %}
                            Ce post a été <strong>masqué par un modérateur</strong>.
                        {% elseif post.isDeleted() %}
                            Ce post a été <strong>supprimé</strong>.
                        {% endif %}
                    </div>
                </div>
            {% endif %}

            {# Titre #}
            <h1 class="display-5 fw-bold mb-3">{{ post.title }}</h1>

            {# Métadonnées #}
            <div class="d-flex flex-wrap gap-3 text-muted mb-4">
                <span>
                    <i class="bi bi-person-circle"></i> 
                    {{ post.author.username }}
                </span>
                <span>
                    <i class="bi bi-clock"></i> 
                    {{ post.createdAt|date('d/m/Y à H:i') }}
                </span>
            </div>

            {# Contenu principal #}
            <div class="post-content fs-5 lh-lg mb-5">
                {{ post.content|nl2br }}
            </div>

            {# Votes #}
            <div class="mb-5">
                {% include 'partials/posts/_post_votes.html.twig' with {
                    post: post,
                    postScores: postScores|default({}),
                    userVote: userVote
                } %}
            </div>

            <hr class="my-5">

            {# Section Commentaires #}
            <section id="comments">
                <h3 class="mb-4 d-flex align-items-center gap-2">
                    Commentaires
                    <span class="badge bg-secondary rounded-pill">{{ comments|length }}</span>
                </h3>

                {# Formulaire de commentaire #}
                {% if commentForm is defined and commentForm is not null %}
                    <div class="mb-5 bg-white border rounded-3 p-4 shadow-sm">
                        {% include 'partials/comments/_comment_form.html.twig' with {form: commentForm} %}
                    </div>
                {% else %}
                    <div class="alert alert-info mb-5">
                        <i class="bi bi-info-circle me-2"></i>
                        Connectez-vous pour laisser un commentaire.
                    </div>
                {% endif %}

                {# Liste des commentaires #}
                {% if comments is not empty %}
                    <div class="comments-list">
                        {% for comment in comments %}
                            {% include 'partials/comments/_comment_item.html.twig' with {comment: comment} %}
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="text-muted text-center py-5">
                        Aucun commentaire pour le moment.<br>
                        Soyez le premier à réagir !
                    </p>
                {% endif %}
            </section>

        </article>

    </div>
</div>

{% endblock %}